# Database (SQLite — defaults to services/api/data/leadsgen.db if unset)
# DATABASE_URL=sqlite:///./data/leadsgen.db
# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Search providers — configure per user in Settings UI (encrypted in database)
# Legacy global fallback (optional):
# SEARCH_PROVIDER=mock

# Email sending — configure per user in Settings UI (encrypted in database)
# Legacy global fallback (optional):
# EMAIL_PROVIDER=mock

# Campaign defaults
DEFAULT_DAILY_SEND_LIMIT=20
DEFAULT_PER_DOMAIN_LIMIT=3
DEFAULT_SENDING_WINDOW_START=09:00
DEFAULT_SENDING_WINDOW_END=17:00

# App
APP_NAME=LeadsGen
ENVIRONMENT=development

# Enrichment
ENRICHMENT_USER_AGENT=LeadsGenBot/0.1 (B2B enrichment; respects robots.txt)
ENRICHMENT_REQUEST_TIMEOUT=10
ENRICHMENT_RATE_LIMIT_SECONDS=1.0
ENRICHMENT_MAX_PAGES=3

# API public URL (used for unsubscribe links in generated emails)
API_PUBLIC_URL=http://localhost:8000
